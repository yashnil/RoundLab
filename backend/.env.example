# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key-here

# CORS Origins (comma-separated, no spaces)
# Production example: https://your-app.vercel.app,https://www.your-domain.com
# Development example: http://localhost:3000,http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Environment (development, staging, production)
# Set to "production" to disable dev-only endpoints
ENVIRONMENT=development
